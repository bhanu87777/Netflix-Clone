# Server
PORT=5000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=netflix_clone

# Auth - change this to a long random string
JWT_SECRET=change-me-to-a-long-random-secret

# TMDB - get a free key at https://www.themoviedb.org/settings/api
# Either the v3 API Key or the v4 Read Access Token works here
TMDB_API_KEY=
